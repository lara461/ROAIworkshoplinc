{
  "note": "All collections are prefixed with fow_ (Future of Work) so this workshop's data can safely share a Firebase project with the base Executive AI Workshop tool without colliding.",
  "entities": {
    "Workshop": {
      "title": "Workshop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "adminSecret": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": {
          "type": "string",
          "enum": ["survey", "challenges_ready", "groups_open", "groups_locked", "board_review", "presentation", "commitments", "closed"],
          "description": "Drives which step is visible to participants in real time"
        },
        "presentationGroupId": { "type": "string", "description": "Group currently on screen in plenary presentation mode" }
      },
      "required": ["name", "date", "adminSecret", "createdAt", "status"]
    },
    "Participant": {
      "title": "Participant",
      "type": "object",
      "properties": {
        "workshopId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "token": { "type": "string", "description": "Unique access token -> /w/:token" },
        "status": { "type": "string", "enum": ["invited", "survey_done"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workshopId", "email", "token", "status", "createdAt"]
    },
    "SurveyResponse": {
      "title": "SurveyResponse",
      "type": "object",
      "properties": {
        "participantId": { "type": "string" },
        "workshopId": { "type": "string" },
        "orgSize": { "type": "string" },
        "aiRelationship": { "type": "string" },
        "biggestConcern": { "type": "string" },
        "futureOfWorkView": { "type": "string", "description": "Open text answer" },
        "moveTimeline": { "type": "string" },
        "futureVision": { "type": "string" },
        "ownershipPreference": { "type": "string" },
        "employeeFreedom": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participantId", "workshopId", "createdAt"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "Step 1 output — generated by the admin from aggregated survey answers",
      "type": "object",
      "properties": {
        "workshopId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "themes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workshopId", "title", "description", "createdAt"]
    },
    "GroupSignup": {
      "title": "GroupSignup",
      "description": "Step 2 — a participant's choice of challenge before groups are locked",
      "type": "object",
      "properties": {
        "workshopId": { "type": "string" },
        "challengeId": { "type": "string" },
        "participantId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workshopId", "challengeId", "participantId", "createdAt"]
    },
    "Group": {
      "title": "Group",
      "description": "Finalized group (max 4 people) after admin locks group formation",
      "type": "object",
      "properties": {
        "workshopId": { "type": "string" },
        "challengeId": { "type": "string" },
        "name": { "type": "string" },
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workshopId", "challengeId", "name", "participantIds", "createdAt"]
    },
    "GroupSolution": {
      "title": "GroupSolution",
      "description": "Shared, collaboratively-edited answer document for a group (doc id == groupId)",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "workshopId": { "type": "string" },
        "solution": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["groupId", "workshopId"]
    },
    "BoardChallenge": {
      "title": "BoardChallenge",
      "description": "Step 3 — simulated C-level board challenge on a group's solution (doc id == groupId)",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "workshopId": { "type": "string" },
        "personaChallenges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "objection": { "type": "string" },
              "roaiTools": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["groupId", "workshopId", "personaChallenges", "createdAt"]
    },
    "Commitment": {
      "title": "Commitment",
      "description": "Step 5 — individual 30-day action commitment",
      "type": "object",
      "properties": {
        "participantId": { "type": "string" },
        "workshopId": { "type": "string" },
        "action": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participantId", "workshopId", "action", "createdAt"]
    }
  },
  "firestore": {
    "fow_workshops": { "schema": "Workshop" },
    "fow_participants": { "schema": "Participant" },
    "fow_survey_responses": { "schema": "SurveyResponse" },
    "fow_challenges": { "schema": "Challenge" },
    "fow_group_signups": { "schema": "GroupSignup" },
    "fow_groups": { "schema": "Group" },
    "fow_group_solutions": { "schema": "GroupSolution" },
    "fow_board_challenges": { "schema": "BoardChallenge" },
    "fow_commitments": { "schema": "Commitment" }
  }
}
