{
  "note": "All collections are prefixed with fow_ (Future of Work) so this workshop's data can safely share a Firebase project with the base Executive AI Workshop tool without colliding.",
  "entities": {
    "Workshop": {
      "title": "Workshop",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "adminSecret": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "setup",
            "working",
            "presentation",
            "closed"
          ],
          "description": "setup (prep) -> working (launched, groups running their 3 timed activities) -> presentation (plenary) -> closed"
        },
        "presentationGroupId": {
          "type": "string"
        },
        "presentationSections": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Which parts of the presenting group's work are shown on /present, chosen live by the admin"
        }
      },
      "required": [
        "name",
        "date",
        "adminSecret",
        "createdAt",
        "status"
      ]
    },
    "Participant": {
      "title": "Participant",
      "type": "object",
      "properties": {
        "workshopId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": [
            "participant",
            "facilitator"
          ],
          "description": "Fixed property of the person, not the group. Facilitators write their group's answers; everyone writes their own 30-day commitment."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "workshopId",
        "email",
        "role",
        "createdAt"
      ],
      "description": "No per-participant token anymore \u2014 everyone uses the same shared workshop link (/w/:workshopId) and identifies themselves by picking their name and confirming with email."
    },
    "SurveyResponse": {
      "title": "SurveyResponse",
      "description": "The pre-work survey runs OUTSIDE the tool; these records are imported from a CSV/XLSX file (or entered by hand for a manually-added participant).",
      "type": "object",
      "properties": {
        "participantId": {
          "type": "string"
        },
        "workshopId": {
          "type": "string"
        },
        "aiRelationship": {
          "type": "string"
        },
        "futureVision": {
          "type": "string"
        },
        "opportunitiesChallenges": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "participantId",
        "workshopId",
        "createdAt"
      ]
    },
    "Group": {
      "title": "Group",
      "description": "Created manually by the admin BEFORE challenges exist (max 4 participantIds, max 1 facilitator). Once the workshop launches, each group runs its own 3 timed activities via currentStep/stepStartedAt.",
      "type": "object",
      "properties": {
        "workshopId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "participantIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "challengeId": {
          "type": [
            "string",
            "null"
          ],
          "description": "Set once a Challenge option is selected for this group"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "currentStep": {
          "type": "string",
          "enum": [
            "initial",
            "board",
            "actions",
            "done"
          ],
          "description": "Drives the facilitator's 3-activity stepper"
        },
        "stepStartedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Start of the current 15-minute activity, for the countdown timer"
        }
      },
      "required": [
        "workshopId",
        "name",
        "participantIds",
        "createdAt"
      ]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "Generated PER GROUP from that group's members' survey answers (C-level/boardroom framing). Multiple options per group; admin or facilitator picks one. Editable after generation.",
      "type": "object",
      "properties": {
        "workshopId": {
          "type": "string"
        },
        "groupId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "themes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "option",
            "selected"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "workshopId",
        "groupId",
        "title",
        "description",
        "status",
        "createdAt"
      ]
    },
    "GroupSolution": {
      "title": "GroupSolution",
      "description": "Doc id == groupId. Only the group's facilitator(s) can write initialSolution/revisedSolution; other members see them read-only.",
      "type": "object",
      "properties": {
        "groupId": {
          "type": "string"
        },
        "workshopId": {
          "type": "string"
        },
        "initialSolution": {
          "type": "string"
        },
        "initialUpdatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "revisedSolution": {
          "type": "string"
        },
        "revisedUpdatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "initialSubmitted": {
          "type": "boolean"
        },
        "initialSubmittedAt": {
          "type": "string",
          "format": "date-time"
        },
        "revisedSubmitted": {
          "type": "boolean"
        },
        "revisedSubmittedAt": {
          "type": "string",
          "format": "date-time"
        },
        "action30": {
          "type": "string",
          "description": "30-day actions \u2014 group activity, written by the facilitator, right after the revised answer"
        },
        "action60": {
          "type": "string"
        },
        "action90": {
          "type": "string"
        },
        "actionsSubmitted": {
          "type": "boolean"
        },
        "actionsSubmittedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "groupId",
        "workshopId"
      ]
    },
    "BoardChallenge": {
      "title": "BoardChallenge",
      "description": "Doc id == groupId. Simulated C-level board challenge on the group's initial solution.",
      "type": "object",
      "properties": {
        "groupId": {
          "type": "string"
        },
        "workshopId": {
          "type": "string"
        },
        "personaChallenges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": {
                "type": "string"
              },
              "objection": {
                "type": "string"
              }
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "groupId",
        "workshopId",
        "personaChallenges",
        "createdAt"
      ]
    },
    "KnowledgeDoc": {
      "title": "KnowledgeDoc",
      "description": "A reference document (uploaded or pasted) the admin adds when setting up a workshop. Grounds both the generated challenges and the C-level board feedback in this workshop's own material instead of generic content.",
      "type": "object",
      "properties": {
        "workshopId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "workshopId",
        "name",
        "content",
        "createdAt"
      ]
    },
    "GroupReport": {
      "title": "GroupReport",
      "description": "Doc id == groupId. One report PER GROUP, generated in the Report tab after the workshop is marked closed: executive summary, key insight, how the group's thinking evolved from their solution to their reviewed solution, and next steps.",
      "type": "object",
      "properties": {
        "groupId": {
          "type": "string"
        },
        "workshopId": {
          "type": "string"
        },
        "executiveSummary": {
          "type": "string"
        },
        "keyInsight": {
          "type": "string"
        },
        "evolution": {
          "type": "string"
        },
        "recommendedNextSteps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "groupId",
        "workshopId",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "fow_workshops": {
      "schema": "Workshop"
    },
    "fow_participants": {
      "schema": "Participant"
    },
    "fow_survey_responses": {
      "schema": "SurveyResponse"
    },
    "fow_groups": {
      "schema": "Group"
    },
    "fow_challenges": {
      "schema": "Challenge"
    },
    "fow_group_solutions": {
      "schema": "GroupSolution"
    },
    "fow_board_challenges": {
      "schema": "BoardChallenge"
    },
    "fow_knowledge_docs": {
      "schema": "KnowledgeDoc"
    },
    "fow_group_reports": {
      "schema": "GroupReport"
    }
  }
}